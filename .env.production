# ── Ontology Engine — Production Environment Template ─────────────────────
# Deploy target: Railway (backend) + Vercel (frontend) + Supabase (auth/db)
#
# INSTRUCTIONS:
# 1. Copy this to your Railway service's environment variables
# 2. Fill in the actual secrets (marked with CHANGEME)
# 3. Do NOT commit this file with real secrets
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://fareqnzxhodvgdkboeff.supabase.co
SUPABASE_ANON_KEY=CHANGEME                           # Dashboard → Settings → API → anon/public key
SUPABASE_SERVICE_KEY=CHANGEME                        # Dashboard → Settings → API → service_role key
SUPABASE_JWT_SECRET=CHANGEME                         # Dashboard → Settings → API → JWT Secret

# ── LLM (Node 2 Extraction) ──────────────────────────────────────────────
GEMINI_API_KEY=CHANGEME                              # Google AI Studio → API Keys
# OPENAI_API_KEY=CHANGEME                            # Optional: GPT-4 fallback
# ANTHROPIC_API_KEY=CHANGEME                         # Optional: Claude fallback

# ── API Server ────────────────────────────────────────────────────────────
API_ENABLED=true
PORT=8000                                            # Railway overrides this automatically
CORS_ORIGINS=https://your-app.vercel.app             # Set to your Vercel deployment URL

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_IP_DAILY=50
MAX_CONCURRENT_REQUESTS=3
GLOBAL_DAILY_BUDGET=500

# ── Circuit Breaker ───────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN=300

# ── File Upload ───────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
