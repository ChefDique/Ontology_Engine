# Ontology Engine — Environment Variables
# Copy this file to .env and fill in your values.

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://fareqnzxhodvgdkboeff.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XutNgFw0FTZE6xL_GCM-lg_Q08_iXXF
SUPABASE_SERVICE_KEY=            # Get from Supabase Dashboard → Settings → API → service_role key
SUPABASE_JWT_SECRET=             # Get from Supabase Dashboard → Settings → API → JWT Secret

# ── LLM (Node 2 Extraction) ──────────────────────────────────────────
GEMINI_API_KEY=                  # Google AI Studio → API Keys
# OPENAI_API_KEY=               # Optional: GPT-4 fallback
# ANTHROPIC_API_KEY=            # Optional: Claude fallback

# ── API Server ────────────────────────────────────────────────────────
API_ENABLED=true                 # Kill switch: set to 'false' to disable
PORT=8000
CORS_ORIGINS=*                   # Comma-separated allowed origins

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_PER_IP_DAILY=50
MAX_CONCURRENT_REQUESTS=3
GLOBAL_DAILY_BUDGET=500

# ── Circuit Breaker ───────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN=300     # seconds

# ── File Upload ───────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
