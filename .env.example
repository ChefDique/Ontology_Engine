# Ontology Engine — Environment Configuration
# Copy this file to .env and fill in your values

# LLM API Keys (at least one required for Node 2)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default LLM provider: openai | anthropic | google
LLM_PROVIDER=openai

# OCR Configuration
TESSERACT_PATH=/usr/local/bin/tesseract
# AWS_ACCESS_KEY_ID=          # Optional: for AWS Textract
# AWS_SECRET_ACCESS_KEY=      # Optional: for AWS Textract

# CRM API Keys (Workstream Gamma)
# ACCULYNX_CLIENT_ID=
# ACCULYNX_CLIENT_SECRET=
# JOBNIMBUS_API_KEY=

# HITL Configuration
CONFIDENCE_THRESHOLD=0.85     # Below this → human review required
